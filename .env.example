# ID магазина в ЮKassa (найди в личном кабинете ЮKassa)
YOOKASSA_SHOP_ID=1333678

# Секретный ключ из ЮKassa (раздел "Интеграция → Ключи API")
YOOKASSA_SECRET_KEY=live_iIEDgMPk_93bVFvbIhykBTM_ZExWAMdE-yO3pgPZC9w

# URL фронтенда (куда ЮKassa вернёт пользователя после оплаты)
