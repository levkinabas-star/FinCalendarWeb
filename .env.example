# ============================================
# FinCalendar API — Environment Variables
# ============================================
# Скопируйте этот файл в .env и заполните значения

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=4000

# ============================================
# Application URL (URL вашего фронтенда — ЮKassa вернёт сюда после оплаты)
# ВАЖНО: без слэша в конце!
# ============================================
APP_URL=https://ваш-домен.ru

# ============================================
# YooKassa Payment Configuration
# Получить в личном кабинете ЮKassa: https://yookassa.ru
# ============================================
YOOKASSA_SHOP_ID=ваш_shop_id_из_юкассы
YOOKASSA_SECRET_KEY=ваш_секретный_ключ_из_юкассы
YOOKASSA_WEBHOOK_SECRET=опционально_для_вебхуков

# ============================================
# Pricing (цены в рублях)
# ============================================
PRICE_MONTHLY=100.00
PRICE_YEARLY=1000.00

# ============================================
# CORS (через запятую, без пробелов)
# ============================================
ALLOWED_ORIGINS=https://ваш-домен.ru,http://localhost:5173
