# ============================================
# FinCalendar Frontend — Environment Variables
# ============================================
# Скопируйте этот файл в .env и заполните значения

# URL задеплоенного бэкенда (API)
# ВАЖНО: Это должен быть HTTPS URL вашего бэкенда
VITE_API_URL=https://api.ваш-домен.ru

# Supabase — ОПЦИОНАЛЬНО (для синхронизации данных между устройствами)
# Если не используете Supabase — оставьте пустыми
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
